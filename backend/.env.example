# ── Database ────────────────────────────────────────────────────────────────
# Local dev fallback (zero-setup, single-writer — NOT for multi-agent load):
# DATABASE_URL=sqlite+aiosqlite:///sqlite.db
#
# Supabase (recommended). Use the **Connection Pooler** string for the app
# (Project Settings → Database → Connection pooling, "Transaction" mode, 6543),
# and rewrite the scheme to postgresql+asyncpg://
DATABASE_URL=postgresql+asyncpg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DB_SSL=true
DB_DISABLE_STATEMENT_CACHE=true

# For Alembic migrations, prefer the **direct** connection (port 5432), since
# the pooler is transaction-scoped. Set this in your shell before migrating:
#   DATABASE_URL=postgresql+asyncpg://postgres.<ref>:<pw>@db.<ref>.supabase.co:5432/postgres alembic upgrade head

SECRET_KEY=super_secret_key_change_in_production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=480
